{% if pss_intent %}
/*
 * Verification intent (structured natural language):
 * {{ pss_intent | replace('\n', '\n * ') }}
 */
{% endif %}
component {{ design_name }}_comp {
{% if reset_ports %}
    action do_reset {
        // Reset behavior inferred from reset-role port(s).
    }
{% endif %}
{% for port in control_ports %}
    action drive_{{ port.name }} {
        // Drive behavior inferred from control input '{{ port.name }}'.
    }
{% endfor %}
{% for port in data_ports %}
    action sample_{{ port.name }} {
        // Sample behavior inferred from data output '{{ port.name }}'.
    }
{% endfor %}

{% if register_map %}
    // ── PSS register actions (from register map)
{% for reg in register_map.registers %}
{% for field in reg.fields %}
{% if field.pss_action %}
    action {{ field.pss_action }} {
        // Register: {{ reg.name }} offset {{ reg.offset }}
        // Field: {{ field.field_name }}
        // Access: {{ field.access }}
        // Req: {{ field.req_id if field.req_id else 'none' }}
        // LLM_FILL_REG_ACTION_START
        // Extend: add field write/read via regmodel.
        // LLM_FILL_REG_ACTION_END
    }
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
    action main {
{% if reset_ports %}
        do_reset r;
{% endif %}
{% for port in control_ports %}
        drive_{{ port.name }} d_{{ loop.index }};
{% endfor %}
{% for port in data_ports %}
        sample_{{ port.name }} s_{{ loop.index }};
{% endfor %}

        // LLM_FILL_CONSTRAINTS_START
        constraint c_default {
            // Extend: add scenario constraints here.
        }
        // LLM_FILL_CONSTRAINTS_END

        {% if coverage_labels %}
        {% for cov in coverage_labels %}
        {% if not cov.waived %}
        covergroup {{ cov.label }} {
            {% if cov.req_id %}
            // Traces to: {{ cov.req_id }}
            {% endif %}
            // {{ cov.display }}
            // Source: {{ cov.source }}
            // Extend: add coverage bin definitions here.
        }
        {% else %}
        // WAIVED: {{ cov.label }}
        // Reason: {{ cov.waiver_reason }}
        {% if cov.req_id %}// Requirement: {{ cov.req_id }}{% endif %}
        {% endif %}
        {% endfor %}
        {% else %}
        covergroup cg_default {
            // Extend: add covergroup bins for this design.
        }
        {% endif %}
    }
}
