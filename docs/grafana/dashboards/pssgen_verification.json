          "url_options": { "method": "GET", "data": "" },
          "type": "json",
          "parser": "backend",
          "root_selector": "$",
          "columns": [
            { "selector": "d034_phase",         "text": "Phase",        "type": "string" },
            { "selector": "summary.WRITTEN",     "text": "Written",      "type": "number" },
