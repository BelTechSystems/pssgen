    },
    {
      "id": 8,
      "type": "table",
      "title": "D-034 Phase 1 Sequence Status",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_PSSGEN-GAP-REPORT}"
      },
      "targets": [
        {
